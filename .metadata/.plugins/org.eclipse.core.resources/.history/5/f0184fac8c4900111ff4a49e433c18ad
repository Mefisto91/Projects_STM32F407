

#include <stdint.h>

//Declaro las macros con para realizar la mascara
#define PLLM (0x3F << 0)
#define PLLN (0x1FF << 6)
#define PLLP (0x3 << 16)

int main(void)
{
	//Declaro mis variables
	uint32_t *RCC_CR		=	(uint32_t*) 0x40023800;
	uint32_t *RCC_PLLCFGR	=	(uint32_t*) 0x40023804;
	uint32_t *RCC_AHB1ENR	=	(uint32_t*) 0x40023830;
	uint32_t *RCC_CFGR		=	(uint32_t*) 0x40023808;

	uint32_t *GPIOA_MODER	=	(uint32_t*) 0x40020000;
	uint32_t *GPIOA_ODR		=	(uint32_t*) 0x40020014;

	uint32_t *GPIOD_MODER	=	(uint32_t*) 0x40020000;
	uint32_t *GPIOD_ODR		=	(uint32_t*) 0x40020014;

	uint32_t *FLASH_ACR		=	(uint32_t*) 0x40023C00;


	*RCC_CR			|=	(1 << 16);
	while (!(*RCC_CR & (1 << 17)));

	*FLASH_ACR		&=	~(7 << 0);
	*FLASH_ACR		|=	(5 << 0);

	*RCC_PLLCFGR	&=	~(PLLP | PLLN | PLLM);
	*RCC_PLLCFGR 	|= 	(1 << 22) | (0 << 16) | (336 << 6) | (8 << 0);

	*RCC_CR			|=	(1 << 24);
    while (!(*RCC_CR & (1 << 25)));

	*RCC_CFGR		&=	~((3 << 21) | (7 << 24) | (3 << 0));
	*RCC_CFGR		|=	(1 << 22) | (1 << 24) | (1 << 1);

	*RCC_AHB1ENR	|=	(1 << 0) | (1 << 3);

	*GPIOA_MODER	&=	~(3 << 16);
	*GPIOA_MODER	|=	(1 << 16);

	*GPIOD_MODER	&=	~(3 << 24);
	*GPIOD_MODER	|=	(1 << 24);

	while(1){
		*GPIOD_MODER ^= (1 << 16);
		for (volatile int i = 0; i < 1000000; i++);
	}
}


