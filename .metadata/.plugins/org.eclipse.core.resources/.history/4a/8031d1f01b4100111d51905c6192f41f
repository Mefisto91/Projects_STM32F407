
#include <stdint.h>

int main(void)
{

	uint32_t *clk 		= (uint32_t*) 0x40023830;
	uint32_t *gpioDER 	= (uint32_t*) 0x40020C00;
	uint32_t *gpioDOut 	= (uint32_t*) 0x40020C14;

	*clk 		|= (1 << 3);
	*gpioDER 	&= ~(3 << 25);
	*gpioDER 	|= (1 << 25);

	while(1){
		for (uint32_t i=0; i<=100000; i++) *gpioDOut = (2 << 12);

		for (uint32_t i=0; i<=100000; i++) *gpioDOut &= ~(2 << 12);

	}
}
