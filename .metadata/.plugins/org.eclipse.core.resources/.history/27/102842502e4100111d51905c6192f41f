
#include <stdint.h>

int main(void)
{

	uint32_t *Clk 		= (uint32_t*) 0x40023830;

	uint32_t *GpioDER 	= (uint32_t*) 0x40020C00;
	uint32_t *GpioDOut 	= (uint32_t*) 0x40020C14;

	uint32_t *GpioAER 	= (uint32_t*) 0x40020000;
	uint32_t *GpioAIn 	= (uint32_t*) 0x40020010;


	*Clk 		|= (1 << 3);
	*Clk 		|= (1 << 0);

	*GpioDER 	&= ~(1 << 24);
	*GpioDER 	|= (1 << 24);

	*GpioAER	&= ~(3 << 0);


	while(1){
		uint8_t Valor	= (uint8_t) (*GpioAIn & 0x1);

		if (Valor == 1){
			for (uint32_t i=0; i<=500000; i++) *GpioDOut = (1 << 12);

			*GpioDOut &= ~(1 << 12);
		}
	}
}
