	*TimerOneBDTR 	|= (1 << 15);

	*TimerOneEGR 	|= (1 << 0);

	*GPIOAMODER 	&= ~(3 << 16);
	*GPIOAMODER 	|= (2 << 16);

	*GPIOAAFRH  	&= ~(0xF << 0);
	*GPIOAAFRH  	|=  (1 << 0);

	*TimerOneCR1 	|= (1 << 0);

	while(1){
	}
